# Project Specific
# ============================================================================

# Output files (jika ada)
output/
results/
predictions/
submissions/
*.csv.bak
*.kilo
# Log files
*.log
logs/

# Temporary files
temp/
tmp/
*.tmp
*_temp.*
*_backup.*

# Model checkpoints (jika ada model yang disimpan)
models/
checkpoints/
*.pkl
*.pickle
*.joblib
*.h5
*.pt
*.pth

# Data files (OPTIONAL - uncomment jika tidak ingin commit data)
# train.csv
# test.csv
# *.csv

# Experimental files
experimental/
sandbox/
scratch/
test_*.py.bak
*_old.*
*_deprecated.*

# Documentation build files
docs/_build/
docs/_static/
docs/_templates/

# Database files
*.db
*.sqlite
*.sqlite3

# Environment variables
.env
.env.local
.env.*.local

# ============================================================================
# Backup & Archive
# ============================================================================

# Backup files
*.bak
*.backup
*~
*.orig

# Archive files
*.zip
*.tar
*.tar.gz
*.tgz
*.rar
*.7z

# ============================================================================
# Exceptions (files to keep in repo)
# ============================================================================

# Keep these files even if they match patterns above
!.gitignore
!README.md
!requirements.txt

# Keep main project files
!main.py
!test_functions.py
!train.csv
!test.csv

# Keep documentation
!*.md
!*.txt
!PENJELASAN_ALGORITMA.md
!RINGKASAN_IMPLEMENTASI.txt
!LAPORAN_PENYELESAIAN.txt
!QUICK_REFERENCE.txt

# ============================================================================
# End of .gitignore
# ============================================================================
